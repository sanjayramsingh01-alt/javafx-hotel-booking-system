<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
Purpose: Staff dashboard screen for the Hotel Booking System.
Authors: Andrea Goorachan, Sanjay Ramsingh
Version: v1.0
Date: 2/24/2026
-->

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cts.javafxhotelbookingapp.StaffDashboardController">

    <!-- Menu -->
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="Logout" onAction="#handleLogout"/>
                        <MenuItem text="Exit" onAction="#handleExit"/>
                    </items>
                </Menu>

                <Menu text="Help">
                    <items>
                        <MenuItem text="FAQs" onAction="#handleFAQ"/>
                        <MenuItem text="User Manual" onAction="#handleUserManual"/>
                        <MenuItem text="About" onAction="#handleAbout"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane>

            <!-- Background Image -->
            <ImageView fitHeight="700.0" fitWidth="1100.0" preserveRatio="false">
                <image>
                    <Image url="@../../../img/hotel_background.jpg" />
                </image>
            </ImageView>

            <!-- Main Dashboard -->
            <VBox alignment="CENTER"
                  spacing="30.0"
                  style="-fx-background-color: rgba(255,255,255,0.85); -fx-padding: 40; -fx-background-radius: 15;">

                <!-- Title -->
                <Label style="-fx-text-fill: #0d2b45; -fx-font-size: 32px; -fx-font-weight: bold;"
                       text="Staff Dashboard">
                    <font>
                        <Font name="Berlin Sans FB Demi Bold" size="28.0" />
                    </font>
                </Label>

                <!-- Navigation Buttons -->
                <GridPane hgap="20.0" vgap="20.0" alignment="CENTER">

                    <Button fx:id="btnAddRoom"
                            text="Add Room"
                            onAction="#openAddRoom"
                            prefHeight="55.0" prefWidth="220.0"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                            GridPane.rowIndex="0" GridPane.columnIndex="0"/>

                    <Button fx:id="btnViewBookings"
                            text="View Bookings"
                            onAction="#openViewBookings"
                            prefHeight="55.0" prefWidth="220.0"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                            GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Button fx:id="btnViewGuests"
                            text="View Guests"
                            onAction="#openViewGuests"
                            prefHeight="55.0" prefWidth="220.0"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                            GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                    <Button fx:id="btnCheckInOut"
                            text="Check In / Out"
                            onAction="#openCheckInOut"
                            prefHeight="55.0" prefWidth="220.0"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                            GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Button fx:id="btnGuestReport"
                            text="Guest Report"
                            onAction="#openGuestReport"
                            prefHeight="55.0" prefWidth="220.0"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                            GridPane.rowIndex="2" GridPane.columnIndex="0"/>

                    <Button fx:id="btnBookingReport"
                            text="Booking Report"
                            onAction="#openBookingReport"
                            prefHeight="55.0" prefWidth="220.0"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                            GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                </GridPane>

                <!-- Logout Button -->
                <Button fx:id="btnLogout"
                        text="Logout"
                        onAction="#logout"
                        prefHeight="50.0" prefWidth="200.0"
                        style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"/>

            </VBox>

        </StackPane>
    </center>

</BorderPane>