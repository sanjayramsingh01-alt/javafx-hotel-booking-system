<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
Purpose: Check in and check out screen for the Hotel Booking System.
Authors: Andrea Goorachan, Sanjay Ramsingh
Version: v1.0
Date: 2/24/2026
-->

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cts.javafxhotelbookingapp.CheckInOutController">

    <!-- Menu -->
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem onAction="#handleLogout" text="Logout" />
                        <MenuItem onAction="#handleExit" text="Exit" />
                    </items>
                </Menu>
                <Menu text="Help">
                    <items>
                        <MenuItem onAction="#handleFAQ" text="FAQs" />
                        <MenuItem onAction="#handleUserManual" text="User Manual" />
                        <MenuItem onAction="#handleAbout" text="About" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane>

            <!-- Background image -->
            <ImageView fitHeight="700.0" fitWidth="1100.0" preserveRatio="false">
                <image>
                    <Image url="@../../../img/hotel_background.jpg"/>
                </image>
            </ImageView>

            <!-- Main form -->
            <VBox alignment="CENTER" spacing="20.0"
                  style="-fx-background-color: rgba(255,255,255,0.85); -fx-padding: 30; -fx-background-radius: 15;">

                <!-- Title -->
                <Label text="Check In / Check Out"
                       style="-fx-text-fill: #0d2b45; -fx-font-size: 32px; -fx-font-weight: bold;">
                    <font>
                        <Font name="Berlin Sans FB Demi Bold" size="28.0" />
                    </font>
                </Label>

                <!-- Booking details -->
                <GridPane hgap="15.0" vgap="15.0" alignment="CENTER">

                    <Label text="Select Booking"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>

                    <ComboBox fx:id="cmbBookings"
                              onAction="#showBookingDetails"
                              prefWidth="300.0"
                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-font-size: 14px;"
                              GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Booking ID"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtBookingId" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Guest Name"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtGuestName" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Room Number"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtRoomNumber" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Booking Date"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtBookingDate" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Check-out Date"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="5" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtCheckoutDate" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <Label text="Number of Guests"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="6" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtNumberOfGuests" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <Label text="Status"
                           style="-fx-text-fill: #1f3c5b; -fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="7" GridPane.columnIndex="0"/>

                    <TextField fx:id="txtBookingStatus" editable="false"
                               prefWidth="300.0"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cfd8dc; -fx-padding: 5 10; -fx-font-size: 14px;"
                               GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                    <Label fx:id="lblStatusDisplay"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"
                           GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                </GridPane>

                <!-- Action buttons -->
                <HBox alignment="CENTER" spacing="15.0">

                    <Button fx:id="btnCheckIn"
                            onAction="#checkInBooking"
                            prefHeight="40.0" prefWidth="120.0"
                            text="Check In"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <Button fx:id="btnCheckOut"
                            onAction="#checkOutBooking"
                            prefHeight="40.0" prefWidth="120.0"
                            text="Check Out"
                            style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <Button fx:id="btnBack"
                            onAction="#goBack"
                            prefHeight="40.0" prefWidth="100.0"
                            text="Back"
                            style="-fx-background-color: #e0e0e0; -fx-text-fill: #333333; -fx-background-radius: 10; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                </HBox>

                <!-- Status message -->
                <Label fx:id="lblMessage"
                       style="-fx-text-fill: #1f3c5b; -fx-font-size: 14px; -fx-font-weight: bold;" />

            </VBox>

        </StackPane>
    </center>

</BorderPane>