<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
Purpose: Registration screen for the Hotel Booking System.
Authors: Andrea Goorachan, Sanjay Ramsingh
Version: v1.0
Date: 2/24/2026
-->

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cts.javafxhotelbookingapp.RegisterUserController">

    <center>
        <AnchorPane prefHeight="700.0" prefWidth="1100.0">

            <!-- Background Image -->
            <ImageView fitHeight="700.0" fitWidth="1100.0" preserveRatio="false"
                       AnchorPane.topAnchor="0.0"
                       AnchorPane.bottomAnchor="0.0"
                       AnchorPane.leftAnchor="0.0"
                       AnchorPane.rightAnchor="0.0">
                <image>
                    <Image url="@../../../img/RG_Background.jpg" />
                </image>
            </ImageView>

            <!-- Main Form -->
            <VBox alignment="CENTER" spacing="20.0"
                  maxWidth="420.0"
                  prefWidth="420.0"
                  style="-fx-background-color: rgba(255,255,255,0.75); -fx-background-radius: 18; -fx-padding: 30;">

                <AnchorPane.leftAnchor>340.0</AnchorPane.leftAnchor>
                <AnchorPane.rightAnchor>340.0</AnchorPane.rightAnchor>
                <AnchorPane.topAnchor>120.0</AnchorPane.topAnchor>

                <!-- Title -->
                <Label text="Register New User"
                       style="-fx-text-fill: #0d2b45; -fx-font-size: 34px; -fx-font-weight: bold;"/>

                <!-- Input Fields -->
                <GridPane alignment="CENTER" hgap="15.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="130.0" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="240.0"/>
                    </columnConstraints>

                    <Label text="First Name" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtFirstName" prefWidth="240"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Last Name" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtLastName" prefWidth="240"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Username" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtUsername" prefWidth="240"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Password" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="3"/>
                    <PasswordField fx:id="txtPassword" prefWidth="240"
                                   style="-fx-background-radius: 8; -fx-border-radius: 8;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Email" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="4"/>
                    <TextField fx:id="txtEmail" prefWidth="240"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Phone Number" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="5"/>
                    <TextField fx:id="txtPhone" prefWidth="240"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;"
                               GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <Label text="Role" style="-fx-font-size: 15px; -fx-font-weight: bold;" GridPane.rowIndex="6"/>
                    <ComboBox fx:id="cBoxRole" prefWidth="240"
                              style="-fx-background-radius: 8; -fx-border-radius: 8;"
                              GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                </GridPane>

                <!-- Action Buttons -->
                <HBox alignment="CENTER" spacing="20.0">

                    <Button fx:id="btnRegister"
                            text="Register"
                            onAction="#registerUser"
                            prefHeight="42" prefWidth="140"
                            style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <Button fx:id="btnBack"
                            text="Back to Login"
                            onAction="#goBack"
                            prefHeight="42" prefWidth="140"
                            style="-fx-background-color: #e0e0e0; -fx-text-fill: #333; -fx-background-radius: 10; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                </HBox>

                <!-- Message Label -->
                <Label fx:id="lblMessage"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"
                       textFill="RED"/>

            </VBox>

        </AnchorPane>
    </center>

</BorderPane>